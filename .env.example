# Copy this file to .env (or .env.local) and tweak values for your shell.
# Both files are gitignored.

# When the agent finishes detecting tags on a page, do we auto-start
# visualization generation for every tag in parallel ("true") or wait for
# the user to click a tag before spending tokens on it ("false", the
# production default — keeps Codex usage proportional to what the student
# actually opens, which matters on long documents)?
#
# Default if unset: "false". Set to exactly "true" to opt into eager
# generation. Either way it's toggleable live from the Settings popover.
NEXT_PUBLIC_AUTO_GENERATE_VIZ=false

# When the visualizer crashes on an LLM-generated spec (e.g. SyntaxError in
# the Three.js / Canvas setup code), we send the broken code + error back
# to codex and ask it to fix it. This caps the number of *additional*
# generation calls per tag — total = 1 + this value.
#
# Default: 3 (i.e. up to 4 attempts per tag).
NEXT_PUBLIC_MAX_VIZ_GEN_RETRIES=3
